rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isUser(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isHouseholdMember(householdId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/households/$(householdId))
        && request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberUids;
    }

    // A non-member may join a household whose invite is still unused, but ONLY
    // by adding exactly themselves to memberUids and marking the invite used.
    // Knowledge of the household id comes from the single-use invite code.
    function isJoiningHousehold() {
      return request.auth != null
        && resource.data.inviteUsed == false
        && !(request.auth.uid in resource.data.memberUids)
        && (request.auth.uid in request.resource.data.memberUids)
        && request.resource.data.memberUids.hasAll(resource.data.memberUids)
        && request.resource.data.memberUids.size() == resource.data.memberUids.size() + 1
        && request.resource.data.inviteUsed == true;
    }

    match /users/{uid} {
      allow read, write: if isUser(uid);
    }

    match /households/{householdId} {
      // Members can read; a prospective joiner can read a household whose invite
      // is still unused (to validate the code before joining).
      allow read: if isHouseholdMember(householdId)
        || (request.auth != null && resource.data.inviteUsed == false);
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.memberUids;
      allow update: if isHouseholdMember(householdId) || isJoiningHousehold();
      allow delete: if isHouseholdMember(householdId);
    }

    match /expenses/{expenseId} {
      // Owner can always read their own. Household members can also read
      // shared/split expenses (so partners see combined shared spending);
      // personal expenses stay private to their owner.
      allow read: if isUser(resource.data.uid)
        || (resource.data.poolType in ['shared', 'split']
            && isHouseholdMember(resource.data.householdId));
      allow create: if isUser(request.resource.data.uid)
        && isHouseholdMember(request.resource.data.householdId);
      // The owner may edit anything. A household member may ALSO update a
      // shared/split expense, but only to cast/withdraw a removal vote
      // (changing nothing but the removalVotes field). Both partners voting
      // triggers a Cloud Function that performs the actual delete.
      allow update: if isUser(resource.data.uid)
        || (resource.data.poolType in ['shared', 'split']
            && isHouseholdMember(resource.data.householdId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['removalVotes']));
      // Only the owner may delete directly (personal expenses); shared removals
      // go through the vote + Cloud Function (Admin SDK, which bypasses rules).
      allow delete: if isUser(resource.data.uid);
    }

    // recurringExpenses/{ruleId}: a user's monthly recurring-expense templates.
    // The client materializes them into real expenses. Owner-scoped, mirroring
    // the expenses create rule (must be a household member to create one).
    match /recurringExpenses/{ruleId} {
      allow read, update, delete: if isUser(resource.data.uid);
      allow create: if isUser(request.resource.data.uid)
        && isHouseholdMember(request.resource.data.householdId);
    }

    // inviteCodes/{code}: readable by any authenticated user (needed to look up
    // a household by code during join). Writable by any authenticated user (the
    // creator writes it on household creation).
    match /inviteCodes/{code} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // plaidItems/{uid}: holds the user's Plaid access token. SERVER-ONLY.
    // No client may ever read or write this; only the Admin SDK (Cloud
    // Functions) bypasses rules. Deny everything explicitly.
    match /plaidItems/{uid} {
      allow read, write: if false;
    }

    // pendingTransactions/{txId}: detected transactions awaiting the user's
    // confirmation. Only the server (Admin SDK) creates them. The owning user
    // may read and delete (dismiss/confirm) their own; no client creates/updates.
    match /pendingTransactions/{txId} {
      allow read, delete: if isUser(resource.data.uid);
      allow create, update: if false;
    }
  }
}
